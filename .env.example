# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Stripe Webhook Secret
# Get this from https://dashboard.stripe.com/webhooks after creating the webhook endpoint
# Or from Stripe CLI: stripe listen --print-secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs
# Create these in Stripe Dashboard > Products > Add Product
# Starter: $99/mo with 14-day trial
STRIPE_STARTER_PRICE_ID=price_...
# Pro: $199/mo with 14-day trial
STRIPE_PRO_PRICE_ID=price_...

# App URL (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
