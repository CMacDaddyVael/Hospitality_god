# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for OAuth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — get from Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_AGENCY_MONTHLY=price_...

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — configure in Supabase dashboard under Auth > Providers
# No env vars needed here — configured in Supabase UI
