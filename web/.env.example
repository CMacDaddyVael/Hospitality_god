# =============================================================================
# VAEL Host — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# =============================================================================
# STRIPE — Payments & Subscriptions
# =============================================================================

# Your Stripe secret key.
# Test mode:  starts with sk_test_...
# Live mode:  starts with sk_live_...
# Get it from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY_HERE

# Your Stripe publishable key (used client-side).
# Test mode:  starts with pk_test_...
# Live mode:  starts with pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Webhook signing secret — used to verify that webhook events came from Stripe.
# For local development: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
#   and copy the "whsec_..." value it prints.
# For production: create a webhook endpoint in the Stripe Dashboard pointing to
#   https://your-vercel-url.vercel.app/api/webhooks/stripe
#   and copy the signing secret from that endpoint's settings.
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Stripe Price ID for the Pro tier ($49/mo recurring).
# Test:  price_XXXXXXXXXXXXXXXXXXXXXXXXXX  (from test mode dashboard)
# Live:  price_XXXXXXXXXXXXXXXXXXXXXXXXXX  (from live mode dashboard)
# See README.md → "Stripe Setup" for instructions on creating this product/price.
# Test card: 4242 4242 4242 4242, any future expiry, any CVC
STRIPE_PRO_PRICE_ID=price_YOUR_PRO_PRICE_ID_HERE

# Stripe Price ID for the Autopilot tier ($149/mo recurring).
# This product exists as a placeholder — it is NOT yet sold to customers.
# Created in advance so the checkout flow can reference it when the tier launches.
STRIPE_AUTOPILOT_PRICE_ID=price_YOUR_AUTOPILOT_PRICE_ID_HERE

# =============================================================================
# SUPABASE — Database & Auth
# =============================================================================

# Your Supabase project URL.
# Find it at: https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous (public) key — safe to expose client-side.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Supabase service role key — KEEP SECRET, server-side only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# AI — Claude (Anthropic)
# =============================================================================

# Your Anthropic API key for Claude.
# Get it from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# =============================================================================
# APP CONFIG
# =============================================================================

# The public URL of your app (no trailing slash).
# Local:      http://localhost:3000
# Production: https://your-vercel-url.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
